{
  "name": "renalo-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist/assets && tailwindcss -i ./src/styles.css -o ./dist/assets/styles.css --minify && bun build ./src/main.tsx --target=browser --outdir=dist --entry-naming=assets/index-[hash].[ext] --asset-naming=assets/[name]-[hash].[ext] && cp src/sw.js dist/sw.js && bun ./scripts/write-index.ts",
    "check": "biome check . && tsc --noEmit",
    "format": "biome check --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@react-stately/utils": "^3.12.1",
    "@react-types/overlays": "^3.10.0",
    "@untitledui/icons": "^0.0.22",
    "input-otp": "^1.4.2",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-aria": "^3.50.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "react-router": "8.2.0",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tailwindcss/cli": "^4.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^4.3.3",
    "tailwindcss-react-aria-components": "^2.2.0",
    "typescript": "7.0.2"
  }
}
