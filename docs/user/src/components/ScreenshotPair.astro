---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
  desktopCaption?: string;
  mobileCaption?: string;
}

const {
  desktop,
  mobile,
  alt,
  desktopCaption = "Desktop",
  mobileCaption = "Mobile",
} = Astro.props;
---

<div class="renalo-screenshot-pair">
  <figure>
    <Image src={desktop} alt={`${alt} on desktop`} loading="lazy" />
    <figcaption>{desktopCaption}</figcaption>
  </figure>
  <figure class="mobile-capture">
    <Image src={mobile} alt={`${alt} on mobile`} loading="lazy" />
    <figcaption>{mobileCaption}</figcaption>
  </figure>
</div>

<style>
  .renalo-screenshot-pair {
    display: grid;
    grid-template-columns: minmax(0, 2.3fr) minmax(14rem, 0.7fr);
    align-items: start;
    gap: 1.25rem;
    margin-block: 1.75rem 2.5rem;
  }

  figure {
    min-width: 0;
    margin: 0;
  }

  :global(.renalo-screenshot-pair img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid #d1d7e0;
    border-radius: 0.75rem;
    background: #fff;
  }

  figcaption {
    margin-top: 0.55rem;
    color: #687080;
    font-size: 0.8rem;
    text-align: center;
  }

  @media (max-width: 50rem) {
    .renalo-screenshot-pair {
      grid-template-columns: 1fr;
    }

    .mobile-capture {
      width: min(100%, 22rem);
      justify-self: center;
    }
  }
</style>
